{
  "name": "@fidemark/badge",
  "version": "0.2.0",
  "private": true,
  "description": "Fidemark verification badge, React component + Web Component embed",
  "license": "Apache-2.0",
  "author": "Vincent Cibelli (VinciDev) <contact@vincidev.com>",
  "homepage": "https://fidemark.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fidemark/badge.git"
  },
  "bugs": {
    "url": "https://github.com/fidemark/badge/issues"
  },
  "keywords": [
    "fidemark",
    "attestation",
    "provenance",
    "eas",
    "badge",
    "web-component",
    "react"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./web-component": {
      "types": "./dist/web-component.d.ts",
      "import": "./dist/web-component.js",
      "require": "./dist/web-component.cjs"
    },
    "./region": {
      "types": "./dist/region.d.ts",
      "import": "./dist/region.js",
      "require": "./dist/region.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "jsdom": "^25.0.1",
    "@types/jsdom": "^21.1.7",
    "vitest": "^2.1.5",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
